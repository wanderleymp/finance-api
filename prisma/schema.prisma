generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum UserActionType {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

enum NotificationType {
  USER_CREATED
  USER_UPDATED
  USER_PERMISSIONS_CHANGED
  LOGIN_FAILED
  SECURITY_ALERT
  LOGIN_SUCCESSFUL
}

model User {
  id              String   @id @default(uuid())
  user_name       String   @unique
  password        String
  role            UserRole @default(USER)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  performedActions UserActionLog[] @relation("PerformedActions")
  userActions     UserActionLog[] @relation("UserActions")
  notifications   Notification[] @relation("UserNotifications")
}

model UserActionLog {
  id          String         @id @default(uuid())
  actionType  UserActionType
  performedBy String         // ID do usuário que realizou a ação
  targetUser  String         // ID do usuário afetado
  details     Json?          // Detalhes adicionais da ação
  createdAt   DateTime       @default(now())

  // Relacionamento opcional com o usuário que realizou a ação
  performer   User?          @relation("PerformedActions", fields: [performedBy], references: [id])
  // Relacionamento opcional com o usuário afetado
  user        User?          @relation("UserActions", fields: [targetUser], references: [id])
}

model Notification {
  id          String           @id @default(uuid())
  type        NotificationType
  description String
  createdAt   DateTime         @default(now())
  userId      String?          // Usuário relacionado à notificação (opcional)
  user        User?            @relation(fields: [userId], references: [id], name: "UserNotifications")
  isRead      Boolean          @default(false)
  metadata    Json?            // Metadados adicionais do evento
}
