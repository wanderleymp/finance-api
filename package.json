{
  "name": "finance-api",
  "version": "1.2.0",
  "description": "API de finanças com autenticação JWT",
  "main": "dist/app.js",
  "type": "commonjs",
  "scripts": {
    "start": "node dist/app.js",
    "build": "npx tsc",
    "dev": "nodemon --config nodemon.json",
    "test": "NODE_ENV=test jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "create-admin": "ts-node scripts/create_admin.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "generate:entities": "ts-node scripts/generate-entities.ts"
  },
  "keywords": [
    "finance",
    "api",
    "jwt",
    "typescript"
  ],
  "author": "Equipe de Desenvolvimento",
  "license": "ISC",
  "dependencies": {
    "amqplib": "^0.10.5",
    "argon2": "^0.31.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/amqplib": "^0.10.6",
    "@types/axios": "^0.9.36",
    "@types/cors": "^2.8.17",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^4.17.21",
    "@types/express-validator": "^2.20.33",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.17.9",
    "@types/pg-connection-string": "^0.1.1",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "pg": "^8.13.1",
    "pg-connection-string": "^2.7.0",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typeorm": "^0.3.20",
    "typeorm-extension": "^3.6.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
